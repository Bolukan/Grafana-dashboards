      "panel-1": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "de9ejk2fk91j4b"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"sql\"\r\nimport \"join\"\r\nimport \"influxdata/influxdb/secrets\"\r\n\r\nusername = secrets.get(key: \"MYSQL_USERNAME\")\r\npassword = secrets.get(key: \"MYSQL_PASSWORD\")\r\nmysql_server = secrets.get(key: \"MYSQL_SERVER\")\r\n\r\nble = sql.from(\r\n    driverName: \"mysql\",\r\n    dataSourceName: \"${username}:${password}@tcp(${mysql_server})/sensor\",\r\n    query: \"SELECT UPPER(mac) as topic, location as location FROM device WHERE model = 'LYWSD03MMC_ATC' LIMIT 50\",\r\n)\r\n\r\ndata = from(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"ble\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Power\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"voltage\")\r\n  |\u003e aggregateWindow(every: v.windowPeriod, fn: median, createEmpty: false)\r\n  |\u003e group()\r\n\r\njoin.inner(\r\n    left: data,\r\n    right: ble,\r\n    on: (l, r) =\u003e l.topic == r.topic,\r\n    as: (l, r) =\u003e ({l with location: r.location}),\r\n)\r\n  |\u003e group(columns: [\"_time\", \"_value\"], mode: \"except\")"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
