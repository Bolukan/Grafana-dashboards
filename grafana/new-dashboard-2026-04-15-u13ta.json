                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "de9ejk2fk91j4b"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"sql\"\r\nimport \"join\"\r\nimport \"influxdata/influxdb/secrets\"\r\n\r\nusername = secrets.get(key: \"MYSQL_USERNAME\")\r\npassword = secrets.get(key: \"MYSQL_PASSWORD\")\r\nmysql_server = secrets.get(key: \"MYSQL_SERVER\")\r\n\r\ndevices = sql.from(\r\n  driverName: \"mysql\",\r\n  dataSourceName: \"${username}:${password}@tcp(${mysql_server})/sensor\",\r\n  query: \"SELECT * FROM grafana\",\r\n)\r\n\r\ndata = from(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Electrical\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"current\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"zigbee\")\r\n  |\u003e aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\r\n  |\u003e group()\r\n\r\njoin.left(\r\n    left: data,\r\n    right: devices,\r\n    on: (l, r) =\u003e l.topic == r.topic,\r\n    as: (l, r) =\u003e ({l with location: r.location}),\r\n)\r\n  |\u003e group(columns: [\"_time\", \"_value\"], mode: \"except\")\r\n"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
