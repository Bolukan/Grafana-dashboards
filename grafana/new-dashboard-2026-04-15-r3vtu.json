                        "query": "import \"date\"\r\n\r\nfrom(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"topic\"] == \"pi58\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Powergas\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"p1mon\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"day\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"consumption_gas_m3\")\r\n  |\u003e increase()\r\n  |\u003e rename(columns: {_value: \"Gas_CY\"})\r\n  |\u003e yield(name: \"CY\")\r\n\r\nfrom(bucket: \"Residence\")\r\n  |\u003e range(start: date.sub(d: 1y, from: v.timeRangeStart), stop: date.sub(d: 1y, from: v.timeRangeStop))\r\n  |\u003e filter(fn: (r) =\u003e r[\"topic\"] == \"pi58\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Powergas\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"p1mon\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"day\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"consumption_gas_m3\")\r\n  |\u003e increase()\r\n  |\u003e timeShift(duration: 1y)\r\n  |\u003e rename(columns: {_value: \"Gas_LY1\"})\r\n  |\u003e yield(name: \"LY1\")\r\n\r\nfrom(bucket: \"Residence\")\r\n  |\u003e range(start: date.sub(d: 2y, from: v.timeRangeStart), stop: date.sub(d: 2y, from: v.timeRangeStop))\r\n  |\u003e filter(fn: (r) =\u003e r[\"topic\"] == \"pi58\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Powergas\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"p1mon\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"day\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"consumption_gas_m3\")\r\n  |\u003e increase()\r\n  |\u003e timeShift(duration: 2y)\r\n  |\u003e rename(columns: {_value: \"Gas_LY2\"})\r\n  |\u003e yield(name: \"LY2\")\r\n \r\n"
