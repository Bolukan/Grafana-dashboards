            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "de9ejk2fk91j4b"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"date\"\r\n\r\ncurrentTime = now()\r\ncurrentMinute = uint(v: date.minute(t: currentTime))\r\nquarterMinute = currentMinute - (currentMinute % uint(v: 15))\r\nhourTruncated = date.truncate(t: currentTime, unit: 1h)\r\ncurrentQuarterStart = date.add(d: duration(v: string(v: quarterMinute) + \"m\"), to: hourTruncated)\r\n\r\ndata = from(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"DayAhead\")\r\n  |\u003e filter(fn: (r) =\u003e contains(value: r[\"_field\"], set: [\"priceincl\"]))\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"quarter\")\r\n  |\u003e aggregateWindow(every: 15m, fn: mean, createEmpty: false, timeSrc: \"_start\")\r\n\r\n\r\ncurrent = data\r\n  |\u003e map(fn: (r) =\u003e ({ r with _value: if r._time == currentQuarterStart then r._value else 0.0 }))\r\n  |\u003e set(key: \"_field\", value: \"current\")\r\n\r\nnormal = data\r\n  |\u003e map(fn: (r) =\u003e ({ r with _value: if r._time != currentQuarterStart then r._value else 0.0 }))\r\n  |\u003e set(key: \"_field\", value: \"normal\")\r\n\r\nunion(tables: [current, normal])"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
