                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"date\"\r\n\r\nfrom(bucket: \"Residence\")\r\n  |\u003e range(start: -35d, stop: 0d)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"DayAhead\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"priceincl\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"quarter\")\r\n  |\u003e map(fn: (r) =\u003e {\r\n    hourNum = date.hour(t: r._time)\r\n    hourStr = if hourNum \u003c 10 then \"0\" + string(v: hourNum) else string(v: hourNum)\r\n    quarterNum = int(v: date.minute(t: r._time) / 15) * 15\r\n    quarterStr = if quarterNum \u003c 10 then \"0\" + string(v: quarterNum) else string(v: quarterNum)\r\n    return { r with hour: hourStr + \":\" + quarterStr}\r\n  })\r\n  |\u003e group(columns: [\"hour\"], mode: \"by\")\r\n  |\u003e mean(column: \"_value\")\r\n  |\u003e group()\r\n  |\u003e sort(columns: [\"hour\"])"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
