                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"timezone\"\r\noption location = timezone.location(name: \"Europe/Amsterdam\")\r\n\r\nhour_water = from(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Watermeter\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"hour\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"topic\"] == \"pi58\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"watermeter_consumption_liter\")\r\n  |\u003e aggregateWindow(every: 1h, fn: sum, createEmpty: false)\r\n\r\nhour_water\r\n  |\u003e hourSelection(start: 0, stop: 5)\r\n  |\u003e map(fn: (r) =\u003e ({ r with duration: \"nacht\" }))\r\n  |\u003e yield(name: \"nacht\")\r\n\r\nhour_water\r\n  |\u003e hourSelection(start: 6, stop: 11)\r\n  |\u003e map(fn: (r) =\u003e ({ r with duration: \"ochtend\" }))\r\n  |\u003e yield(name: \"ochtend\")\r\n\r\nhour_water\r\n  |\u003e hourSelection(start: 12, stop: 17)\r\n  |\u003e map(fn: (r) =\u003e ({ r with duration: \"middag\" }))\r\n  |\u003e yield(name: \"middag\")\r\n\r\nhour_water\r\n  |\u003e hourSelection(start: 18, stop: 23)\r\n  |\u003e map(fn: (r) =\u003e ({ r with duration: \"avond\" }))\r\n  |\u003e yield(name: \"avond\")\r\n  \r\n"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
