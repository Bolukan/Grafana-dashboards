                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "from(bucket: \"Residence\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"protocol\"] == \"p1mon\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"Powergas\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"consumption_kw\" or r[\"_field\"] == \"production_kw\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"topic\"] == \"pi58\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"duration\"] == \"minute\")\r\n  |\u003e aggregateWindow(every: 15m, fn: sum, createEmpty: false, timeSrc: \"_start\")\r\n  |\u003e toFloat()\r\n  |\u003e map(fn: (r) =\u003e ({r with _value: r._value / 60.0}))\r\n  |\u003e pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |\u003e map(fn: (r) =\u003e ({\r\n      r with \r\n      net_kw: r.consumption_kw - r.production_kw\r\n  }))\r\n  |\u003e rename(columns: {net_kw: \"_value\"})\r\n  |\u003e set(key: \"_field\", value: \"net_kw\")\r\n  |\u003e keep(columns: [\"_time\", \"_value\", \"_field\"])\r\n  |\u003e yield(name: \"net_kw\")"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": true,
                    "query": {
                      "datasource": {
                        "name": "be8pllgxdcq2ob"
                      },
                      "group": "marcusolsson-json-datasource",
                      "kind": "DataQuery",
                      "spec": {
                        "cacheDurationSeconds": 300,
                        "fields": [
                          {
                            "jsonPath": "$.*.[0]",
                            "name": "TIMESTAMP",
                            "type": "time"
                          },
                          {
                            "jsonPath": "$.*.[6]",
                            "language": "jsonpath",
                            "name": "CONSUMPTION_DELTA_KWH",
                            "type": "number"
                          },
                          {
                            "jsonPath": "$.*.[7]",
                            "language": "jsonpath",
                            "name": "PRODUCTION_DELTA_KWH",
                            "type": "number"
                          }
                        ],
                        "method": "GET",
                        "params": [
                          [
                            "limit",
                            "60"
                          ]
                        ],
                        "queryParams": "",
                        "urlPath": "/api/v1/powergas/minute?limit=60"
                      },
                      "version": "v0"
                    },
                    "refId": "B"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "calculateField",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "alias": "PRODUCTION_DELTA_KWH_MIN",
                      "binary": {
                        "left": {
                          "fixed": "0"
                        },
                        "operator": "-",
                        "right": {
                          "matcher": {
                            "id": "byName",
                            "options": "B PRODUCTION_DELTA_KWH"
                          }
                        }
                      },
                      "mode": "binary",
                      "reduce": {
                        "reducer": "sum"
                      }
                    }
                  }
                },
                {
                  "group": "filterFieldsByName",
                  "kind": "Transformation",
                  "spec": {
